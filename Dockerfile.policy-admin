FROM python:3.12-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    fastapi==0.115.12 \
    uvicorn==0.32.1 \
    httpx==0.28.1 \
    pydantic==2.10.6 \
    pydantic-settings==2.7.1

# Copy policy admin service
COPY security/policy_admin_service.py /app/

# Expose port
EXPOSE 8183

# Run policy admin service
CMD ["uvicorn", "policy_admin_service:app", "--host", "0.0.0.0", "--port", "8183"]
